@dp.message(DonorForm.blood_group)
async def process_blood(message: Message, state: FSMContext):
    if message.text == "⬅️ Bosh menyuga qaytish": return
    await state.update_data(blood_group=message.text)
    await message.answer("**2. Fuqaroligingizni kiriting:**")
    await state.set_state(DonorForm.citizenship)

