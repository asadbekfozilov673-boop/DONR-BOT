@dp.message(DonorForm.donor_type)
async def process_donor_type(message: Message, state: FSMContext):
    await state.update_data(donor_type=message.text)
    user_data = await state.get_data()
    
    admin_text = (
        f"🚨 **Yangi Donor Ro'yxatdan O'tdi!**\n\n"
        f"👤 **Foydalanuvchi:** {message.from_user.full_name} (@{message.from_user.username})\n"
        f"🆔 **ID:** {message.from_user.id}\n"
        f"🩸 **Qon guruhi:** {user_data.get('blood_group')}\n"
        f"🇺🇿 **Fuqaroligi:** {user_data.get('citizenship')}\n"
        f"🎂 **Yoshi:** {user_data.get('age')}\n"
        f"🚻 **Jinsi:** {user_data.get('gender')}\n"
        f"🏥 **Sog'liq holati:** {user_data.get('health_status')}\n"
        f"🫁 **Donorlik turi:** {user_data.get('donor_type')}"
    )
    
    try:
        await bot.send_message(chat_id=ADMIN_ID, text=admin_text)
        await message.answer("Rahmat! Ma'lumotlaringiz muvaffaqiyatli qabul qilindi va klinika adminiga yuborildi. Tez orada siz bilan bog'lanishadi.", reply_markup=get_main_menu())
    except Exception as e:
        await message.answer("Ma'lumotlar saqlandi, lekin adminga yuborishda muammo bo'ldi. Iltimos, to'g'ridan-to'g'ri admin bilan bog'laning: @liber_kon", reply_markup=get_main_menu())
        logging.error(f"Xatolik: {e}")
        
    await state.clear()

