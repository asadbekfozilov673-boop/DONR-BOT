@dp.message(CommandStart())
async def command_start_handler(message: Message, state: FSMContext) -> None:
    await state.clear()
    await message.answer(
        "Salom! Botimizga xush kelibsiz. Iltimos, tilni tanlang:\n"
        "Здравствуйте! Добро пожаловать. Пожалуйста, выберите язык:\n"
        "Merhaba! Hoş geldiniz. Lütfen bir dil seçin:",
        reply_markup=lang_keyboard
    )

@dp.message(F.text.in_({"🇺🇿 O'zbekcha", "🇷🇺 Русский", "🇹🇷 Türkçe"}))
async def set_language(message: Message, state: FSMContext):
    selected_lang = message.text
    await state.update_data(lang=selected_lang)
    
    if selected_lang == "🇺🇿 O'zbekcha":
        await message.answer("Bosh menyu. O'zingizga kerakli bo'limni tanlang:", reply_markup=get_main_menu())
    elif selected_lang == "🇷🇺 Русский":
        await message.answer("Главное меню. Выберите нужный раздел:", reply_markup=get_main_menu())
    elif selected_lang == "🇹🇷 Türkçe":
        await message.answer("Ana menü. Lütfen bir seçenek seçin:", reply_markup=get_main_menu())

